<div
  class="cart-drawer-overlay"
  aria-hidden="true"
  data-close-cart
></div>

<div
  id="cart-drawer"
  class="cart-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Shopping cart"
  aria-hidden="true"
>
  <div class="cart-drawer__header">
    <h2 class="cart-drawer__title">Your Cart</h2>
    <button
      type="button"
      class="cart-drawer__close"
      data-close-cart
      aria-label="Close cart"
    >
      {%- render 'icon-close' -%}
    </button>
  </div>

  <div class="cart-drawer__items" id="cart-drawer-items" aria-live="polite" aria-label="Cart items">
    <!-- Populated by JS -->
    <div style="padding:48px 0;text-align:center;color:var(--c-text-2);">Loading cart…</div>
  </div>

  <div class="cart-shipping-bar" aria-live="polite" aria-label="Free shipping progress">
    <div class="cart-shipping-bar__track">
      <div class="cart-shipping-bar__fill" id="cart-shipping-fill" style="width:0%"></div>
    </div>
    <p class="cart-shipping-bar__text" id="cart-shipping-text"></p>
  </div>

  <div class="cart-drawer__footer">
    <div class="cart-drawer__subtotal">
      <span style="font-size:0.875rem;color:var(--c-text-2);">Subtotal</span>
      <span class="cart-drawer__subtotal-amount" style="font-weight:700;">{{ cart.total_price | money }}</span>
    </div>
    <p style="font-size:0.75rem;color:var(--c-text-3);margin-bottom:12px;text-align:center;">
      Taxes and shipping calculated at checkout
    </p>
    <a
      href="{{ routes.checkout_url }}"
      class="btn btn-primary btn-full"
      style="height:52px;font-size:0.9375rem;"
    >
      Checkout
    </a>
    <button
      type="button"
      class="btn btn-secondary btn-full"
      style="margin-top:8px;"
      data-close-cart
    >
      Continue Shopping
    </button>
  </div>
</div>

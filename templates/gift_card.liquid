{% layout none %}
{%- assign formatted_balance = gift_card.balance | money_without_trailing_zeros -%}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ shop.name }} Gift Card — {{ formatted_balance }}</title>
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <style>
      @font-face { font-family: 'Anton'; font-style: normal; font-weight: 400; font-display: swap; src: url('{{ "anton-latin.woff2" | asset_url }}') format('woff2'); }
      @font-face { font-family: 'Montserrat'; font-style: normal; font-weight: 400 700; font-display: swap; src: url('{{ "montserrat-latin.woff2" | asset_url }}') format('woff2'); }
    </style>
  </head>
  <body style="background:var(--c-bg);color:var(--c-text);">
    <div class="gift-card-page">
      <a href="{{ routes.root_url }}" class="gift-card-logo" aria-label="{{ shop.name }} home">
        B<span>QUIK</span> VOLLEY
      </a>

      <div class="accent-line" aria-hidden="true"></div>

      <h1 class="text-h2" style="margin:var(--space-lg) 0 var(--space-sm);">Your Gift Card</h1>
      <p style="color:var(--c-text-2);margin-bottom:var(--space-xl);">Share the love for the court.</p>

      <div class="gift-card__balance">{{ formatted_balance }}</div>
      <p style="color:var(--c-text-2);font-size:0.875rem;">Current balance</p>

      <div class="gift-card__code-wrap">
        <p style="font-size:0.75rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--c-text-3);margin-bottom:8px;">Gift Card Code</p>
        <div
          class="gift-card__code"
          id="gift-card-code"
          onclick="copyGiftCardCode()"
          title="Click to copy"
          role="button"
          tabindex="0"
          aria-label="Gift card code: {{ gift_card.code | replace: '-', ' ' }}. Click to copy."
          onkeydown="if(event.key==='Enter'||event.key===' ')copyGiftCardCode()"
        >
          {{ gift_card.code | replace: '-', '&ndash;' }}
        </div>
        <p id="copy-confirm" style="font-size:0.75rem;color:var(--c-success);margin-top:6px;min-height:1em;"></p>
      </div>

      {%- if gift_card.expires_on -%}
        <p class="gift-card__expiry">
          Expires {{ gift_card.expires_on | date: '%B %d, %Y' }}
        </p>
      {%- endif -%}

      {%- unless gift_card.enabled -%}
        <p style="color:var(--c-error);font-weight:600;margin-top:var(--space-md);">This gift card has been disabled.</p>
      {%- endunless -%}

      <div style="display:flex;gap:var(--space-md);flex-wrap:wrap;justify-content:center;margin-top:var(--space-2xl);">
        <a href="{{ routes.root_url }}" class="btn btn-primary">Shop Now</a>
        <button type="button" class="btn btn-secondary" onclick="window.print()">Print</button>
      </div>
    </div>

    <script>
      function copyGiftCardCode() {
        var code = '{{ gift_card.code }}';
        navigator.clipboard?.writeText(code).then(function() {
          document.getElementById('copy-confirm').textContent = 'Copied to clipboard!';
          setTimeout(function() { document.getElementById('copy-confirm').textContent = ''; }, 2500);
        }).catch(function() {
          document.getElementById('copy-confirm').textContent = code;
        });
      }
    </script>
  </body>
</html>

{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ shop.name }} — Coming Soon</title>
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <style>
      @font-face { font-family: 'Anton'; font-style: normal; font-weight: 400; font-display: swap; src: url('{{ "anton-latin.woff2" | asset_url }}') format('woff2'); }
      @font-face { font-family: 'Montserrat'; font-style: normal; font-weight: 400 700; font-display: swap; src: url('{{ "montserrat-latin.woff2" | asset_url }}') format('woff2'); }
      @font-face { font-family: 'Red Hat Text'; font-style: normal; font-weight: 400 700; font-display: swap; src: url('{{ "redhattext-latin.woff2" | asset_url }}') format('woff2'); }
    </style>
  </head>
  <body style="background:var(--c-bg);color:var(--c-text);">
    <div class="password-page">
      <div class="password-logo" aria-label="{{ shop.name }}">
        B<span>QUIK</span> VOLLEY
      </div>

      <div class="accent-line" aria-hidden="true" style="margin-bottom:var(--space-xl);"></div>

      <h1 class="text-h1" style="margin-bottom:var(--space-md);">We're Gearing Up</h1>
      <p style="color:var(--c-text-2);max-width:40ch;margin:0 auto var(--space-2xl);">
        Something big is coming to the court. Drop your email and be the first to know when we launch.
      </p>

      {%- form 'customer', class: 'newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,password-page">
        {%- if form.posted_successfully? -%}
          <p style="color:var(--c-success);font-weight:600;margin-bottom:var(--space-md);">
            You're on the list — we'll be in touch!
          </p>
        {%- elsif form.errors -%}
          <p style="color:var(--c-error);margin-bottom:var(--space-md);">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <div style="display:flex;gap:var(--space-sm);flex-wrap:wrap;justify-content:center;max-width:420px;margin:0 auto;">
          <label for="password-email" class="sr-only">Email address</label>
          <input
            id="password-email"
            type="email"
            name="contact[email]"
            class="form-input"
            placeholder="Your email address"
            required
            aria-required="true"
            style="flex:1;min-width:220px;"
          >
          <button type="submit" class="btn btn-primary">Notify Me</button>
        </div>
      {%- endform -%}

      {%- if shop.password_message != blank -%}
        <p style="color:var(--c-text-2);margin-top:var(--space-xl);max-width:40ch;">{{ shop.password_message }}</p>
      {%- endif -%}

      <!-- Owner login -->
      <p style="position:fixed;bottom:var(--space-md);right:var(--space-md);">
        <a href="/password" style="font-size:0.75rem;color:var(--c-text-3);text-decoration:underline;">Store owner login</a>
      </p>
    </div>
  </body>
</html>

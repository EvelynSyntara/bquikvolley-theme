{{ 'theme.css' | asset_url | stylesheet_tag }}

<div class="collection-header">
  <div class="container">
    {%- if collection.image -%}
      <div class="collection-banner">
        {{
          collection.image
          | image_url: width: 1600
          | image_tag:
            loading: 'eager',
            sizes: '100vw',
            alt: collection.title
        }}
        <div class="collection-banner__content">
          <h1 class="text-h1" data-reveal>{{ collection.title }}</h1>
          {%- if collection.description != blank -%}
            <p style="color:var(--c-text-2);max-width:50ch;margin-top:12px;" data-reveal data-reveal-delay="1">
              {{ collection.description }}
            </p>
          {%- endif -%}
        </div>
      </div>
    {%- else -%}
      <h1 class="text-h1" style="margin-bottom:16px;" data-reveal>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p style="color:var(--c-text-2);max-width:60ch;margin-bottom:32px;" data-reveal data-reveal-delay="1">
          {{ collection.description }}
        </p>
      {%- endif -%}
    {%- endif -%}

    <!-- Toolbar: count + sort + tag filters -->
    <div class="collection-toolbar">
      <span style="font-size:0.8125rem;font-weight:600;color:var(--c-text-3);">
        {{ collection.products_count }} product{% if collection.products_count != 1 %}s{% endif %}
      </span>

      <form id="sort-form" method="get" style="display:flex;align-items:center;gap:8px;">
        {%- if current_tags.size > 0 -%}
          {%- for tag in current_tags -%}
            <input type="hidden" name="q[]" value="{{ tag | escape }}">
          {%- endfor -%}
        {%- endif -%}
        <label for="sort-by" class="text-xs" style="color:var(--c-text-3);">Sort:</label>
        <select
          id="sort-by"
          name="sort_by"
          class="sort-select"
          onchange="document.getElementById('sort-form').submit()"
          aria-label="Sort products by"
        >
          {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
          <option value="manual"{% if sort_by == 'manual' %} selected{% endif %}>Featured</option>
          <option value="best-selling"{% if sort_by == 'best-selling' %} selected{% endif %}>Best Selling</option>
          <option value="created-descending"{% if sort_by == 'created-descending' %} selected{% endif %}>Newest</option>
          <option value="price-ascending"{% if sort_by == 'price-ascending' %} selected{% endif %}>Price: Low &rarr; High</option>
          <option value="price-descending"{% if sort_by == 'price-descending' %} selected{% endif %}>Price: High &rarr; Low</option>
          <option value="title-ascending"{% if sort_by == 'title-ascending' %} selected{% endif %}>A &rarr; Z</option>
          <option value="title-descending"{% if sort_by == 'title-descending' %} selected{% endif %}>Z &rarr; A</option>
        </select>
      </form>
    </div>

    <!-- Tag filter chips -->
    {%- if collection.all_tags.size > 0 -%}
      <div class="collection-filters" role="navigation" aria-label="Product filters" style="margin-bottom:var(--space-xl);">
        {%- for tag in collection.all_tags -%}
          {%- if current_tags contains tag -%}
            <a href="{{ collection.url }}" class="filter-chip active" aria-pressed="true">{{ tag }}</a>
          {%- else -%}
            {{ tag | link_to_tag: tag | replace: '<a ', '<a class="filter-chip" ' }}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<div class="container" style="padding-bottom: var(--space-3xl);">
  {%- paginate collection.products by 24 -%}
    {%- if collection.products.size > 0 -%}
      <div class="products-grid" role="list" aria-label="Products">
        {%- for product in collection.products -%}
          <div role="listitem" data-reveal data-reveal-delay="{{ forloop.index | modulo: 4 }}">
            {%- render 'product-card', product: product -%}
          </div>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination" aria-label="Pagination" style="display:flex;justify-content:center;gap:8px;margin-top:var(--space-2xl);">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="btn btn-secondary">← Prev</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="btn btn-secondary" style="min-width:44px;">{{ part.title }}</a>
            {%- else -%}
              <span class="btn btn-primary" style="min-width:44px;" aria-current="page">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="btn btn-secondary">Next →</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- else -%}
      <div class="cart-empty" style="text-align:center;padding:var(--space-3xl) 0;">
        <p style="color:var(--c-text-2);font-size:1.25rem;margin-bottom:24px;">No products found.</p>
        <a href="{{ routes.root_url }}" class="btn btn-primary">Back to Home</a>
      </div>
    {%- endif -%}
  {%- endpaginate -%}
</div>

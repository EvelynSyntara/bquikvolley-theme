<section class="trust-badges" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="trust-badges__grid">
      {%- for block in section.blocks -%}
        <div class="trust-badge" data-reveal data-reveal-delay="{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="trust-badge__icon">
            {%- case block.settings.icon -%}
              {%- when 'shipping' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 16h6v-6l-4-4H16"/><rect x="1" y="6" width="15" height="10" rx="1"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'returns' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
              {%- when 'quality' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- when 'athletes' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              {%- when 'secure' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {%- endcase -%}
          </div>
          <div class="trust-badge__content">
            <span class="trust-badge__title">{{ block.settings.title }}</span>
            <span class="trust-badge__sub">{{ block.settings.text }}</span>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Badges",
  "tag": "section",
  "settings": [],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping truck" },
            { "value": "returns", "label": "Returns arrow" },
            { "value": "quality", "label": "Star / quality" },
            { "value": "athletes", "label": "Checkmark / verified" },
            { "value": "secure", "label": "Shield / secure" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Subtitle",
          "default": "On orders over $75"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges",
      "blocks": [
        { "type": "badge", "settings": { "icon": "shipping", "title": "Free Shipping", "text": "On orders over $75" } },
        { "type": "badge", "settings": { "icon": "returns", "title": "30-Day Returns", "text": "No questions asked" } },
        { "type": "badge", "settings": { "icon": "athletes", "title": "Court-Tested", "text": "By pro athletes" } },
        { "type": "badge", "settings": { "icon": "quality", "title": "Premium Quality", "text": "Performance fabrics" } }
      ]
    }
  ]
}
{% endschema %}

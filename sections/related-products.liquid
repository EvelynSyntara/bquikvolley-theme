<section
  class="featured-collection section-pad"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-recommendations-url="/recommendations/products"
  aria-label="Related products"
>
  <div class="container">
    <div class="section-header">
      <div>
        <p class="text-xs text-accent" style="margin-bottom:8px;" data-reveal>
          {{ section.settings.eyebrow | default: 'Complete the Kit' }}
        </p>
        <h2 class="text-h2 section-header__title" data-reveal data-reveal-delay="1">
          {{ section.settings.title | default: 'You May Also Like' }}
        </h2>
      </div>
      <a
        href="{{ routes.collections_url }}"
        class="section-header__link"
        data-reveal data-reveal-delay="2"
      >
        View All
        {%- render 'icon-arrow' -%}
      </a>
    </div>

    <div class="collection-carousel-wrap" data-recommendations-target>
      <div
        class="collection-carousel"
        role="list"
        aria-label="Related products"
        id="related-carousel-{{ section.id }}"
      >
        {%- comment -%} Placeholders shown while API loads {%- endcomment -%}
        {%- for i in (1..6) -%}
          <div role="listitem" aria-hidden="true" class="product-card-wrap">
            <div class="product-card" aria-hidden="true">
              <div class="product-card__media skeleton" style="aspect-ratio:3/4;"></div>
              <div class="product-card__info">
                <div class="skeleton" style="height:12px;width:60px;border-radius:4px;margin-bottom:8px;"></div>
                <div class="skeleton" style="height:16px;width:80%;border-radius:4px;margin-bottom:12px;"></div>
                <div class="skeleton" style="height:20px;width:50px;border-radius:4px;"></div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <div class="carousel-progress" aria-hidden="true">
        <div class="carousel-progress__bar" style="width: 15%;"></div>
      </div>

      <div class="carousel-controls">
        <button
          class="carousel-btn"
          data-carousel-prev
          aria-label="Previous"
          aria-controls="related-carousel-{{ section.id }}"
        >{%- render 'icon-arrow-left' -%}</button>
        <button
          class="carousel-btn"
          data-carousel-next
          aria-label="Next"
          aria-controls="related-carousel-{{ section.id }}"
        >{%- render 'icon-arrow' -%}</button>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Related Products",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Complete the Kit"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "You May Also Like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 2,
      "label": "Products to show",
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "Related Products"
    }
  ]
}
{% endschema %}

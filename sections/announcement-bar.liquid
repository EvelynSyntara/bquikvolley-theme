{%- if section.settings.text != blank -%}
  <div
    class="announcement-bar"
    role="region"
    aria-label="Announcement"
    style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};"
  >
    <p class="announcement-bar__text">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
      {%- else -%}
        {{ section.settings.text }}
      {%- endif -%}
    </p>
    {%- if section.settings.dismissible -%}
      <button
        data-dismiss-announcement
        aria-label="Dismiss announcement"
        style="position:absolute;right:16px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:inherit;font-size:1rem;line-height:1;padding:4px;"
      >✕</button>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free shipping on orders over $75 · Use code SPIKE10 for 10% off your first order"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#D4FF00"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0A0A0A"
    },
    {
      "type": "checkbox",
      "id": "dismissible",
      "label": "Show dismiss button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}

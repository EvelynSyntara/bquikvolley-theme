{%- liquid
  assign has_blocks = false
  for block in section.blocks
    if block.settings.text != blank
      assign has_blocks = true
      break
    endif
  endfor
-%}

{%- if section.settings.text != blank or has_blocks -%}
  <div
    class="announcement-bar"
    role="region"
    aria-label="Announcement"
    data-announcement-bar
    data-rotation-speed="{{ section.settings.rotation_speed | times: 1000 }}"
    style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; font-family: 'Red Hat Text', sans-serif;"
  >
    <div class="announcement-bar__messages">
      {%- if has_blocks -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.text != blank -%}
            <p class="announcement-bar__text{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
              {%- else -%}
                {{ block.settings.text }}
              {%- endif -%}
            </p>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <p class="announcement-bar__text is-active">
          {%- if section.settings.link != blank -%}
            <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
          {%- else -%}
            {{ section.settings.text }}
          {%- endif -%}
        </p>
      {%- endif -%}
    </div>

    {%- if section.settings.dismissible -%}
      <button
        data-dismiss-announcement
        aria-label="Dismiss announcement"
        class="announcement-bar__dismiss"
      >&times;</button>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text (fallback if no blocks)",
      "default": "Free shipping on orders over $75 · Use code SPIKE10 for 10% off your first order"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F28500"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "checkbox",
      "id": "dismissible",
      "label": "Show dismiss button",
      "default": true
    },
    {
      "type": "range",
      "id": "rotation_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Message rotation speed",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free shipping on orders over $75"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        { "type": "message", "settings": { "text": "Free shipping on orders over $75" } },
        { "type": "message", "settings": { "text": "Use code SPIKE10 for 10% off your first order" } },
        { "type": "message", "settings": { "text": "New Season Drop — Performance Volleyball Jerseys" } }
      ]
    }
  ]
}
{% endschema %}

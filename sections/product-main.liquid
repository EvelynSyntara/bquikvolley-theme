{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign product_form_id = 'product-form-' | append: section.id -%}

<section
  class="product-main"
  data-section-id="{{ section.id }}"
  data-section-type="product"
>
  <div class="container">
    {%- render 'breadcrumbs' -%}

    <div class="product-layout">
      <!-- Gallery -->
      <div class="product-gallery" data-product-gallery>
        <div class="product-gallery__main">
          <img
            id="main-product-image"
            src="{{ current_variant.featured_image | default: product.featured_image | image_url: width: 1200 }}"
            alt="{{ current_variant.featured_image.alt | default: product.featured_image.alt | escape }}"
            width="1200"
            height="1600"
            loading="eager"
            fetchpriority="high"
            style="transition: opacity 0.2s;"
            data-main-image
            data-zoomable
          >
        </div>

        {%- if product.images.size > 1 -%}
          <div class="product-gallery__thumbnails" role="list" aria-label="Product images">
            {%- for image in product.images limit: 8 -%}
              <button
                class="thumbnail{% if forloop.first %} active{% endif %}"
                role="listitem"
                data-thumb
                data-full-src="{{ image | image_url: width: 1200 }}"
                aria-label="View image {{ forloop.index }}"
                aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
              >
                {{ image | image_url: width: 160 | image_tag: loading: 'lazy', alt: image.alt }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Product Info -->
      <div class="product-info">
        {%- if product.vendor != blank -%}
          <p class="product-vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="product-title">{{ product.title }}</h1>

        <!-- Price -->
        <div class="product-price" id="product-price-{{ section.id }}" data-product-price-container>
          <span data-product-price>
            {{ current_variant.price | money }}
          </span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="product-price__compare" data-compare-price>
              {{ current_variant.compare_at_price | money }}
            </span>
            {%- assign discount = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
            <span class="product-price__badge">–{{ discount }}%</span>
          {%- else -%}
            <span class="product-price__compare" data-compare-price style="display:none;"></span>
          {%- endif -%}
        </div>

        <!-- Variant JSON for JS -->
        <script type="application/json" data-variant-json>
          {{ product.variants | json }}
        </script>

        <!-- Product Form -->
        <!-- data-product-form lives on the wrapper — Liquid form tag can't take hyphenated params -->
        <div data-product-form>
        {%- form 'product', product, id: product_form_id, class: 'product-form' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="variant-section">
                <div class="variant-label">
                  {{ option.name }}
                  <span data-selected-value-{{ forloop.index }}>{{ option.selected_value }}</span>
                </div>

                {%- if option.name == 'Color' or option.name == 'Colour' -%}
                  <div class="color-options" data-option-group="option{{ forloop.index }}" role="group" aria-label="{{ option.name }}">
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        class="color-btn{% if option.selected_value == value %} active{% endif %}"
                        data-option-name="option{{ forloop.index }}"
                        data-option-value="{{ value }}"
                        data-value="{{ value }}"
                        aria-label="{{ value }}"
                        aria-pressed="{{ option.selected_value == value }}"
                        style="background-color: {{ value | downcase | replace: ' ', '' }};"
                        title="{{ value }}"
                      ></button>
                    {%- endfor -%}
                  </div>
                {%- else -%}
                  <div class="size-options" data-option-group="option{{ forloop.index }}" role="group" aria-label="{{ option.name }}">
                    {%- for value in option.values -%}
                      {%- assign variant_available = false -%}
                      {%- for variant in product.variants -%}
                        {%- if variant.available -%}
                          {%- for v_opt in variant.options -%}
                            {%- if v_opt == value -%}
                              {%- assign variant_available = true -%}
                            {%- endif -%}
                          {%- endfor -%}
                        {%- endif -%}
                      {%- endfor -%}
                      <button
                        type="button"
                        class="size-btn{% if option.selected_value == value %} active{% endif %}{% unless variant_available %} unavailable{% endunless %}"
                        data-option-name="option{{ forloop.index }}"
                        data-option-value="{{ value }}"
                        data-value="{{ value }}"
                        aria-pressed="{{ option.selected_value == value }}"
                        {% unless variant_available %}aria-label="{{ value }} - Sold out"{% else %}aria-label="{{ value }}"{% endunless %}
                      >
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                {%- if option.name == 'Size' or option.name == 'size' -%}
                  <button
                    type="button"
                    class="size-guide-link"
                    data-open-size-guide
                    aria-haspopup="dialog"
                  >
                    Size Guide
                  </button>
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <!-- ATC area (observed for sticky bar) -->
          <div data-atc-form-area>
            {%- if current_variant.available -%}
              <button
                type="submit"
                class="btn btn-primary btn-full atc-btn"
                data-atc-btn
                data-variant-id="{{ current_variant.id }}"
                aria-label="Add {{ product.title }} to cart"
              >
                Add to Cart — {{ current_variant.price | money }}
              </button>
            {%- else -%}
              <button
                type="button"
                class="btn btn-secondary btn-full atc-btn"
                data-atc-btn
                disabled
                aria-disabled="true"
              >
                Sold Out
              </button>
            {%- endif -%}
          </div>

          {%- if section.settings.show_dynamic_checkout -%}
            {{ form | payment_button }}
          {%- endif -%}
        {%- endform -%}
        </div><!-- /data-product-form -->

        <!-- Product Description -->
        {%- if product.description != blank -%}
          <div class="product-description rte">
            {{ product.description }}
          </div>
        {%- endif -%}

        <!-- Trust Signals -->
        <div class="product-meta">
          <div class="product-meta__item">
            {%- render 'icon-shipping' -%}
            <span>Free shipping over $75</span>
          </div>
          <div class="product-meta__item">
            {%- render 'icon-returns' -%}
            <span>30-day easy returns</span>
          </div>
          <div class="product-meta__item">
            {%- render 'icon-secure' -%}
            <span>Secure checkout</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Sticky ATC Bar -->
<div
  class="sticky-atc"
  aria-label="Sticky add to cart"
  aria-hidden="true"
>
  <div class="sticky-atc__info">
    <div class="sticky-atc__title">{{ product.title }}</div>
    <div class="sticky-atc__price" data-sticky-price>{{ current_variant.price | money }}</div>
  </div>
  <button
    type="button"
    class="btn btn-primary sticky-atc__btn"
    data-sticky-atc
    aria-label="Add {{ product.title }} to cart"
  >
    Add to Cart
  </button>
</div>

{% schema %}
{
  "name": "Product Main",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "info": "Lets customers buy directly using Shop Pay, PayPal, etc.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sku",
      "label": "Show SKU",
      "default": false
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Product Main"
    }
  ]
}
{% endschema %}

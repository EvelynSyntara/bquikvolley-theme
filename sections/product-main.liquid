{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
-%}

<div
  class="product-main"
  data-section-id="{{ section.id }}"
  data-section-type="product"
>
  <div class="container">
    {%- render 'breadcrumbs' -%}

    <div class="product-layout">

      {%- comment -%} ── Gallery ── {%- endcomment -%}
      <div class="product-gallery" data-product-gallery>
        <div class="product-gallery__main">
          {%- if current_variant.featured_image != blank -%}
            {%- assign main_image = current_variant.featured_image -%}
          {%- elsif product.featured_image != blank -%}
            {%- assign main_image = product.featured_image -%}
          {%- endif -%}

          {%- if main_image != blank -%}
            <img
              id="main-product-image"
              src="{{ main_image | image_url: width: 1200 }}"
              alt="{{ main_image.alt | escape }}"
              width="1200"
              height="1600"
              loading="eager"
              fetchpriority="high"
              data-main-image
              data-zoomable
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="product-gallery__thumbnails" role="list" aria-label="Product images">
            {%- for image in product.images limit: 8 -%}
              {%- assign thumb_src = image | image_url: width: 160 -%}
              {%- assign full_src  = image | image_url: width: 1200 -%}
              <button
                class="thumbnail{% if forloop.first %} active{% endif %}"
                role="listitem"
                data-thumb
                data-full-src="{{ full_src }}"
                aria-label="View image {{ forloop.index }}"
              >
                <img src="{{ thumb_src }}" alt="{{ image.alt | escape }}" loading="lazy" width="80" height="80">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ── Product Info ── {%- endcomment -%}
      <div class="product-info">

        {%- if product.vendor != blank -%}
          <p class="product-vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="product-title">{{ product.title }}</h1>

        {%- comment -%} Price {%- endcomment -%}
        <div class="product-price" id="product-price-{{ section.id }}">
          <span data-product-price>{{ current_variant.price | money }}</span>

          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="product-price__compare" data-compare-price>
              {{ current_variant.compare_at_price | money }}
            </span>
            {%- assign save_amount = current_variant.compare_at_price | minus: current_variant.price -%}
            {%- assign save_pct    = save_amount | times: 100 | divided_by: current_variant.compare_at_price -%}
            <span class="product-price__badge">-{{ save_pct }}%</span>
          {%- else -%}
            <span class="product-price__compare" data-compare-price style="display:none;"></span>
          {%- endif -%}
        </div>

        {%- comment -%} Variant data for JS {%- endcomment -%}
        <script type="application/json" data-variant-json>
          {{ product.variants | json }}
        </script>

        {%- comment -%} Product Form — wrapper div carries data-product-form because
            Liquid tag params cannot contain hyphens {%- endcomment -%}
        <div data-product-form>
          {%- form 'product', product, id: product_form_id, class: 'product-form' -%}

            <input type="hidden" name="id" value="{{ current_variant.id }}">

            {%- unless product.has_only_default_variant -%}
              {%- for option in product.options_with_values -%}

                <div class="variant-section">
                  <div class="variant-label">
                    {{ option.name }}
                    <span class="variant-selected-value">{{ option.selected_value }}</span>
                  </div>

                  {%- if option.name == 'Color' or option.name == 'Colour' -%}
                    <div
                      class="color-options"
                      data-option-group="option{{ forloop.index }}"
                      role="group"
                      aria-label="{{ option.name }}"
                    >
                      {%- for value in option.values -%}
                        {%- assign is_selected = false -%}
                        {%- if option.selected_value == value -%}
                          {%- assign is_selected = true -%}
                        {%- endif -%}
                        <button
                          type="button"
                          class="color-btn{% if is_selected %} active{% endif %}"
                          data-option-group="option{{ forloop.index }}"
                          data-value="{{ value | escape }}"
                          aria-label="{{ value | escape }}"
                          title="{{ value | escape }}"
                          style="background-color:{{ value | downcase | replace: ' ', '' }};"
                        ></button>
                      {%- endfor -%}
                    </div>

                  {%- else -%}
                    <div
                      class="size-options"
                      data-option-group="option{{ forloop.index }}"
                      role="group"
                      aria-label="{{ option.name }}"
                    >
                      {%- for value in option.values -%}
                        {%- assign value_available = false -%}
                        {%- for variant in product.variants -%}
                          {%- if variant.available -%}
                            {%- for v_option in variant.options -%}
                              {%- if v_option == value -%}
                                {%- assign value_available = true -%}
                              {%- endif -%}
                            {%- endfor -%}
                          {%- endif -%}
                        {%- endfor -%}

                        {%- assign is_selected = false -%}
                        {%- if option.selected_value == value -%}
                          {%- assign is_selected = true -%}
                        {%- endif -%}

                        <button
                          type="button"
                          class="size-btn{% if is_selected %} active{% endif %}{% unless value_available %} unavailable{% endunless %}"
                          data-option-group="option{{ forloop.index }}"
                          data-value="{{ value | escape }}"
                          aria-label="{{ value | escape }}{% unless value_available %} - Sold out{% endunless %}"
                        >
                          {{ value }}
                        </button>
                      {%- endfor -%}
                    </div>

                    {%- if option.name == 'Size' or option.name == 'size' -%}
                      <button
                        type="button"
                        class="size-guide-link"
                        data-open-size-guide
                        aria-haspopup="dialog"
                      >
                        Size Guide
                      </button>
                    {%- endif -%}
                  {%- endif -%}
                </div>

              {%- endfor -%}
            {%- endunless -%}

            {%- comment -%} ATC button — observed by JS for sticky bar {%- endcomment -%}
            <div data-atc-form-area>
              {%- if current_variant.available -%}
                <button
                  type="submit"
                  class="btn btn-primary btn-full atc-btn"
                  data-atc-btn
                  data-variant-id="{{ current_variant.id }}"
                  aria-label="Add {{ product.title | escape }} to cart"
                >
                  Add to Cart &mdash; {{ current_variant.price | money }}
                </button>
              {%- else -%}
                <button
                  type="button"
                  class="btn btn-secondary btn-full atc-btn"
                  data-atc-btn
                  disabled
                  aria-disabled="true"
                >
                  Sold Out
                </button>
              {%- endif -%}
            </div>

            {%- if section.settings.show_dynamic_checkout -%}
              {{ form | payment_button }}
            {%- endif -%}

          {%- endform -%}
        </div>

        {%- if product.description != blank -%}
          <div class="product-description rte">
            {{ product.description }}
          </div>
        {%- endif -%}

        <div class="product-meta">
          <div class="product-meta__item">
            {%- render 'icon-shipping' -%}
            <span>Free shipping over $75</span>
          </div>
          <div class="product-meta__item">
            {%- render 'icon-returns' -%}
            <span>30-day easy returns</span>
          </div>
          <div class="product-meta__item">
            {%- render 'icon-secure' -%}
            <span>Secure checkout</span>
          </div>
        </div>

      </div>{%- comment -%} /product-info {%- endcomment -%}
    </div>{%- comment -%} /product-layout {%- endcomment -%}
  </div>{%- comment -%} /container {%- endcomment -%}
</div>{%- comment -%} /product-main {%- endcomment -%}

{%- comment -%} Sticky ATC Bar {%- endcomment -%}
<div class="sticky-atc" aria-label="Sticky add to cart">
  <div class="sticky-atc__info">
    <div class="sticky-atc__title">{{ product.title }}</div>
    <div class="sticky-atc__price" data-sticky-price>{{ current_variant.price | money }}</div>
  </div>
  <button
    type="button"
    class="btn btn-primary sticky-atc__btn"
    data-sticky-atc
    aria-label="Add {{ product.title | escape }} to cart"
  >
    Add to Cart
  </button>
</div>

{% schema %}
{
  "name": "Product Main",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout buttons",
      "info": "Displays Shop Pay, PayPal, and other express checkout options.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    }
  ]
}
{% endschema %}
